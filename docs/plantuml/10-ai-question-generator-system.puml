@startuml 10-ai-question-generator-system
title Sistem AI Question Generator dengan Dual-Source Material

skinparam backgroundColor #F0F0F0
skinparam componentBackgroundColor #FFFFFF
skinparam componentBorderColor #333333
skinparam actorBackgroundColor #87CEEB
skinparam databaseBackgroundColor #FFE5B4
skinparam noteBackgroundColor #FFFFCC
skinparam packageBackgroundColor #F5F5F5

' === ACTORS ===
actor Guru as teacher
actor Admin
actor "OpenAI API" as openai

' === DATABASE ===
database "DashboardGuru\nDatabase" as db

' === COMPONENTS ===
component "SoalController" as controller
component "readMaterials()" as readmat
component "generateQuestions()" as genquestions
component "saveSoal()" as savequestions

component "OpenAIService" as service
component "Material Processor" as matproc
component "Chat Client" as chatclient
component "Response Parser" as respparser

component "Laravel Cache" as cache
component "Material Cache" as matcache
component "Generated Queue" as queue

package "Database Tables" {
    component "Posts\n(serial_id, content)" as posts
    component "Lessons\n(category: materi)" as lessons
    component "Exercise\nExerciseItem\nBank Soal" as exercise
}


' === RELATIONSHIPS ===

' Guru & Admin interactions
teacher -->|1. Akses Generate Soal| controller
teacher -->|2. Pilih Materi\n(post:ID / lesson:ID)| controller
Admin -->|Setup Materials| db

' Controller flow
controller --> readmat
controller --> genquestions
controller --> savequestions

' Read materials
readmat -->|Query Posts| posts
readmat -->|Query Lessons| lessons
readmat --> matcache

' Generate questions flow
genquestions --> matproc
genquestions --> matcache
matproc --> chatclient
matproc --> matcache

' OpenAI call
chatclient -->|POST request| openai
openai -->|JSON response| respparser

' Response handling
respparser --> queue
respparser --> genquestions
respparser --> service

' Save to database
savequestions --> exercise

' Material sources to database
posts --> db
lessons --> db
exercise --> db

' Cache management
matcache --> cache
queue --> cache

' === NOTES ===
note right of posts
  Sumber Materi 1: Post
  ✓ Guru upload
  ✓ Linked to serial_id
  ✓ Format: text/pdf
  
  Token prefix: post:ID
end note

note right of lessons
  Sumber Materi 2: Lesson
  ✓ Admin setup
  ✓ category: materi
  ✓ Format: text
  
  Token prefix: lesson:ID
end note

note left of matproc
  Material Processing:
  1. Check token prefix
  2. Extract ID
  3. Fetch dari source
  4. Merge content
  5. Format for AI
  6. Cache hasil
end note

note above of service
  OpenAI Integration:
  • Model: GPT-4
  • Rate Limiting
  • Error Handling
  • Token Counting
end note

note bottom of teacher
  User Flow:
  1. Select Generator
  2. Choose Material
  3. Configure Prefs
  4. Submit Request
  5. Review Results
  6. Save to Bank
end note

@enduml
