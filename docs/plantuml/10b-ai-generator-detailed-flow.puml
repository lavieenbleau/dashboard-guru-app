@startuml 10b-ai-generator-detailed-flow
title Alur Lengkap AI Question Generator dengan Dual-Source Material

skinparam defaultFontSize 11
skinparam activity {
  BackgroundColor<<DecisionAI>> LightYellow
  BackgroundColor<<ProcessAI>> LightBlue
  BackgroundColor<<APICall>> FFA07A
  BackgroundColor<<Success>> LightGreen
  BackgroundColor<<Error>> LightCoral
  BackgroundColor<<Start>> #90EE90
  BackgroundColor<<End>> #FFB6C1
}

start
:Guru akses fitur\n"Generate Soal dengan AI";

:Tampilkan form:\n- Pilih sumber materi\n- Preferensi soal\n- Jumlah soal;

:Guru memilih sumber materi|
repeat
  switch (Pilih Sumber Materi:) <<DecisionAI>>
  
  case (Post Guru - Upload Material)
    :Tampilkan daftar\nPost milik Guru\n(dari teacher ini);
    :Guru pilih salah satu\nPost File/Text;
    :Token format: post:312;
  
  case (Admin Material - Pembelajaran)
    :Tampilkan daftar\nLesson kategori Materi\n(dari admin);
    :Guru pilih Lesson\nuntuk kelas/tema;
    :Token format: lesson:156;
  
  endswitch
  
repeat while (Pilih sumber lain?) is (Ya)

:Guru klik\n"Generate Questions"|

:BACKEND: readMaterials()\n- Parse token prefix;
if (Token prefix?) then (post:)
  :Query Post table\nwhere id = extracted_id\nAND serial_id = guru_serial;
  :Ambil konten Post;
else (lesson:)
  :Query Lesson table\nwhere id = extracted_id\nAND category = CATEGORY_MATERI;
  :Ambil konten Lesson;
endif

:Validasi material ada?|
if (Material ditemukan?) then (Tidak)
  :Tampilkan error:\n"Material tidak valid"\n"atau tidak punya akses";
  stop
else (Ya)
  :Proses material text;
endif

:Cache material ke\nLaravel Cache\n(duration: 1 jam);

:Format material untuk\nOpenAI prompt:\n- Konten materi\n- Tipe soal\n- Jumlah soal\n- Difficulty level;

:Call OpenAIService\n→ generateQuestions()|

:OpenAIService:\n1. Ambil dari cache\n2. Build prompt template;

:Send request ke\nOpenAI API\n(GPT-4/GPT-3.5)|
if (API Success?) then (Gagal)
  #FFB6C1
  :Catch exception:\n- Rate limit?\n- Token limit?\n- Invalid API key?;
  
  :Log error to storage/logs;
  
  :Tampilkan user:\n(error message);
  
  stop
else (Sukses - 200 OK)
  #90EE90
  :Terima JSON response\ndari OpenAI;
endif

:ResponseParser:\nParse AI output|
:Validasi struktur JSON\npertanyaan yang diterima;

if (Valid JSON?) then (Tidak)
  #FFB6C1
  :Log invalid response;
  :Show error UI;
  stop
else (Ya)
  :Extract questions\nfrom response;
endif

:Queue result ke\nGenerated Questions\nTemporary Storage;

:Tampilkan di Frontend:\n- Preview soal hasil AI\n- Edit fields\n- Accept/Reject options;

:Guru review\npertanyaan yang dibuat|
repeat
  switch (Review & Edit?)
  case (Terima & Simpan)
    :SoalController:\nsaveSoal();
    :Data pertanyaan →\nExercise table;
    :Data items →\nExerciseItem table;
    :Link ke Exercise\nyang tepat;
    :Tampilkan success\nmessage;
    :Redirect ke\nbank soal;
  case (Edit pertanyaan)
    :Guru edit konten\npertanyaan di UI;
    :Validasi & simpan\nedit ke database;
  case (Tolak & Regenerate)
    :Hapus temporary data;
    :Kembali ke form\ndengan history;
  endswitch
repeat while (Ada aksi lain?) is (Ya)

:Pertanyaan masuk\nke Bank Soal|
:Guru bisa:\n- Share ke kelas\n- Ubah tipe soal\n- Tambah/edit soal\n- Hapus soal;

:Selesai;

stop

@enduml
