@startuml 10c-ai-dual-source-architecture
!define COMPONENT_STYLE
!define BGCOLOR #FAFAFA

title Arsitektur Teknis: AI Generator dengan Dual-Source Material Reading

skinparam backgroundColor BGCOLOR
skinparam componentStyle uml2
skinparam packageBackgroundColor #F5F5F5
skinparam componentBackgroundColor #FFFFFF
skinparam componentBorderColor #1E90FF
skinparam noteFontColor #000000

package "Presentation Layer\n(Frontend)" #E8F4F8 {
    [Blade Template]\n"guru/soal/ai-generator.blade.php"
}

package "Request Layer\n(HTTP)" #E8F4F8 {
    [FormRequest]\n"GenerateQuestionsRequest"
    [Input Validation]\n- material_token\n- question_count\n- difficulty_level\n- question_types
}

package "Controller Layer\n(Guru/SoalController)" #FFF8DC {
    [generateSoal()]\n- Receive request
    [readMaterials()]\n- CORE FEATURE\n- Determine source type
}

package "Token Resolver\n(Dual-Source Logic)" #FFE5B4 {
    [Token Parser]\n- Extract prefix\n- Extract ID
    
    [Source Detector]\n✓ post: → Post Model\n✓ lesson: → Lesson Model\n✓ default: → Error
}

package "Material Fetcher\n(DB Layer)" #E0FFE0 {
    database "Post\nTable" as post_table {
        : id\n: serial_id\n: content\n: created_at
    }
    
    database "Lesson\nTable" as lesson_table {
        : id\n: category\n: content\n: created_at
    }
    
    [Post Fetcher]\n- Query: where id = ?\n- Check: serial_id match?\n- Return: Post content
    
    [Lesson Fetcher]\n- Query: where id = ? AND\n  category = CATEGORY_MATERI\n- Return: Lesson content
}

package "Service Layer\n(OpenAIService)" #F0F8FF {
    [Material Processor]\n- Read Post text OR\n- Read Lesson text\n- Merge if multiple
    
    [Cache Manager]\n- Cache key: mat_ + token\n- TTL: 1 hour\n- Reduce duplicate calls
    
    [Prompt Builder]\n- Template rendering\n- Inject material\n- Add preferences
    
    [AI Client]\n- OpenAI chat.completions\n- Model: GPT-4\n- Error handling
}

package "Response Handler" #FFE5E5 {
    [Response Parser]\n- JSON validation\n- Extract questions\n- Type conversion
    
    [Question Validator]\n- Check answer validity\n- Check structure\n- Sanitize text
    
    [Storage Handler]\n- Temp storage\n- Session/Cache
}

package "Persistence Layer" #E0E0E0 {
    database "Exercise\nTable" as exercise_table {
        : id\n: serial_id\n: exercise_type_id\n: is_admin
    }
    
    database "ExerciseItem\nTable" as item_table {
        : id\n: exercise_id\n: question\n: answers
    }
    
    [Exercise Repository]\n- Save exercise\n- Link type & serial
    
    [Item Repository]\n- Save all items\n- Batch insert
}

package "External Services" #FFE5E5 {
    cloud "OpenAI API" as openai_api {
        : POST /chat/completions
        : Model: gpt-4
        : Max tokens configured
    }
}

' === CONNECTIONS ===

[Blade Template] -->|submit form| [FormRequest]

[FormRequest] -->|validated input| [generateSoal()]

[generateSoal()] -->|call readMaterials()| [readMaterials()]

[readMaterials()] -->|parse token| [Token Parser]

[Token Parser] -->|determine source| [Source Detector]

[Source Detector] -->|if post:ID| [Post Fetcher]
[Source Detector] -->|if lesson:ID| [Lesson Fetcher]

[Post Fetcher] -->|SELECT from| post_table
[Lesson Fetcher] -->|SELECT from| lesson_table

[Post Fetcher] -->|pass content| [Material Processor]
[Lesson Fetcher] -->|pass content| [Material Processor]

[Material Processor] -->|check| [Cache Manager]
[Cache Manager] -->|if cached| [Cache Manager]: return cached
[Cache Manager] -->|if not cached| [Prompt Builder]

[Prompt Builder] -->|call| [AI Client]

[AI Client] -->|POST with material| openai_api
openai_api -->|return JSON| [Response Parser]

[Response Parser] -->|validate| [Question Validator]

[Question Validator] -->|if valid| [Storage Handler]
[Question Validator] -->|if invalid| [Storage Handler]: retry/error

[Storage Handler] -->|temp storage| [generateSoal()]: return to controller

[generateSoal()] -->|user review| [Blade Template]

[Blade Template] -->|confirm save| [Exercise Repository]

[Exercise Repository] -->|INSERT| exercise_table
[Item Repository] -->|INSERT batch| item_table

' === KEY FEATURE NOTES ===

note right of [Token Parser]
  Token Format:
  ===============
  post:{id}     → Teacher post
  lesson:{id}   → Admin lesson
  
  Prevents collision
  between sources
end note

note right of [Post Fetcher]
  Post Query:
  ===============
  SELECT * FROM posts
  WHERE id = ?
  AND serial_id = ?
  
  Ensures teacher access
  to their own materials
end note

note right of [Lesson Fetcher]
  Lesson Query:
  ===============
  SELECT * FROM lessons
  WHERE id = ?
  AND category = 'materi'
  
  Stable, sharable
  admin materials
end note

note right of [Material Processor]
  Material Processing:
  ===============
  1. Get raw text from DB
  2. Clean/sanitize content
  3. Truncate if too large
  4. Format for AI prompt
  
  Dual-source support:
  • Post: teacher uploads
  • Lesson: admin content
end note

note right of [Cache Manager]
  Caching Strategy:
  ===============
  Key: "ai_material_{token}"
  TTL: 3600 seconds
  
  Benefits:
  • Reduce DB queries
  • Reduce API costs
  • Faster regeneration
end note

note right of openai_api
  OpenAI Configuration:
  ===============
  • Model: GPT-4
  • Max tokens: 2048
  • Temperature: 0.7
  • Rate limiting: Configured
  
  From .env:
  OPENAI_API_KEY
  OPENAI_ORGANIZATION
end note

note bottom of [Exercise Repository]
  Final Storage:
  ===============
  Exercise linked to:
  • serial_id (teacher)
  • exercise_type_id
  
  Items linked to:
  • exercise_id
  • question content
  • answer options
end note

@enduml
