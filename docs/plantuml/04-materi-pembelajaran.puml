@startuml 04-materi-pembelajaran
title Alur Materi Pembelajaran - DashboardGuru

start

:Guru memilih aplikasi/serial;

:Lihat daftar materi\ndalam serial;

switch (Aksi?)
case (Buat Materi)
  :Pilih struktur kurikulum:\n- Tema\n- Sub Tema\n- Pembelajaran;
  
  :Input data materi:\n- Judul\n- Deskripsi\n- File PDF/Video\n- Link YouTube;
  
  if (Ada file upload?) then (Ya)
    :Upload file ke storage\nValidasi tipe & ukuran;
    
    if (File valid?) then (Tidak)
      :Tampilkan pesan error:\n- Format tidak didukung\n- Ukuran terlalu besar;
      :Kembali ke input data;
      stop
    else (Ya)
      :Simpan data materi\nke database;
    endif
  else (Tidak)
    :Simpan data materi\nke database;
  endif
  
  :Link materi dengan:\n- Tema\n- Sub Tema\n- Pembelajaran;
  
  :Tampilkan pesan sukses;
  
  stop

case (Edit Materi)
  :Pilih materi\nyang akan diedit;
  
  :Tampilkan form edit\ndengan data existing;
  
  :Update data materi;
  
  stop

case (Hapus Materi)
  if (Konfirmasi hapus?) then (Ya)
    :Hapus materi dan\nfile terkait;
    stop
  else (Tidak)
    :Kembali ke daftar materi;
    stop
  endif

case (Lihat Detail)
  :Tampilkan detail materi;
  
  switch (Aksi detail?)
  case (Download File)
    :Download file materi;
    stop
    
  case (Preview)
    :Preview PDF/Video;
    stop
    
  case (Edit)
    :Edit materi;
    stop
    
  case (Kembali)
    :Kembali ke daftar;
    stop
  endswitch
endswitch

@enduml
