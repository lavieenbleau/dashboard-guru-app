@startuml 05-soal-latihan
title Alur Soal dan Latihan - DashboardGuru

start

:Guru memilih aplikasi/serial;

:Lihat daftar soal/latihan;

switch (Aksi?)
case (Buat Soal Baru)
  :Pilih tipe soal:\n- Pilihan Ganda\n- Essay\n- Benar/Salah\n- Menjodohkan;
  
  :Input data latihan:\n- Judul\n- Deskripsi\n- Kompetensi Dasar\n- Durasi pengerjaan;
  
  repeat
    switch (Tipe pertanyaan?)
    case (Pilihan Ganda)
      :Input:\n- Pertanyaan\n- Gambar (optional)\n- 4-5 pilihan\n- Jawaban benar\n- Bobot nilai;
      
    case (Essay)
      :Input:\n- Pertanyaan\n- Gambar (optional)\n- Bobot nilai;
      
    case (Benar/Salah)
      :Input:\n- Pernyataan\n- Gambar (optional)\n- Jawaban benar\n- Bobot nilai;
      
    case (Menjodohkan)
      :Input:\n- Pertanyaan\n- Pasangan jawaban\n- Bobot nilai;
    endswitch
    
  repeat while (Tambah pertanyaan lagi?) is (Ya)
  
  :Validasi total bobot\nnilai = 100;
  
  if (Total = 100?) then (Tidak)
    :Pesan error:\nTotal bobot harus 100;
    :Kembali tambah pertanyaan;
    stop
  else (Ya)
    :Simpan latihan\nke database;
    
    :Link dengan:\n- Kompetensi Dasar\n- Tema/Sub Tema\n- Pembelajaran;
    
    :Tampilkan pesan sukses;
    stop
  endif

case (Edit Soal)
  :Pilih soal\nyang akan diedit;
  
  :Form edit soal;
  
  :Update data soal;
  
  stop

case (Hapus Soal)
  if (Konfirmasi hapus?) then (Ya)
    :Hapus soal dan\nsemua pertanyaan;
    stop
  else (Tidak)
    :Kembali ke daftar;
    stop
  endif

case (Preview Soal)
  :Preview soal\nseperti tampilan siswa;
  
  :Tampilkan soal dalam\nmode preview;
  
  stop
endswitch

@enduml
