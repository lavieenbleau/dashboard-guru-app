@startuml 10e-ai-generator-usecase
!define BGCOLOR #FAFAFA

title Use Case Diagram: AI Question Generator System

skinparam backgroundColor BGCOLOR
skinparam actorBackgroundColor #87CEEB
skinparam usecaseBackgroundColor #FFFACD
skinparam packageBackgroundColor #F0F0F0
skinparam arrowColor #333333

' === ACTORS ===
actor Guru as teacher
actor Admin as admin
actor "OpenAI\nAPI" as ai
actor Siswa as student

' === SYSTEM ===
rectangle "DashboardGuru - AI Question Generator System" as system {
    
    ' === MAIN USE CASES ===
    
    ' Teacher Use Cases
    (Akses Generator Soal) as uc1
    (Pilih Sumber Materi:\nPost atau Lesson) as uc2
    (Konfigurasi Preferensi\nSoal) as uc3
    (Generate Pertanyaan\ndengan AI) as uc4
    (Review Hasil AI) as uc5
    (Edit Pertanyaan) as uc6
    (Simpan ke Bank Soal) as uc7
    (Bagikan ke Kelas) as uc8
    
    ' Admin Use Cases
    (Upload Materi\nKurikulum) as uc9
    (Manage Lesson\nKategori Materi) as uc10
    (Monitor Penggunaan\nAI) as uc11
    (Configure OpenAI\nSettings) as uc12
    
    ' System Use Cases
    (Read Material\nfrom Post) as uc13
    (Read Material\nfrom Lesson) as uc14
    (Cache Material) as uc15
    (Build AI Prompt) as uc16
    (Call OpenAI API) as uc17
    (Parse Response) as uc18
    (Validate Questions) as uc19
    (Store Exercise) as uc20
    (Store ExerciseItems) as uc21
    
    ' Student Use Cases
    (View Bank Soal) as uc22
    (Kerjakan Soal) as uc23
    
    ' === RELATIONSHIPS ===
    
    ' Guru to Teacher Use Cases
    teacher -->|uses| uc1
    teacher -->|uses| uc2
    teacher -->|uses| uc3
    teacher -->|uses| uc4
    teacher -->|uses| uc5
    teacher -->|uses| uc6
    teacher -->|uses| uc7
    teacher -->|uses| uc8
    
    ' Admin to Admin Use Cases
    admin -->|uses| uc9
    admin -->|uses| uc10
    admin -->|uses| uc11
    admin -->|uses| uc12
    
    ' Student Use Cases
    student -->|uses| uc22
    student -->|uses| uc23
    
    ' Main Flow
    uc1 -.->|includes| uc2
    uc2 -.->|includes| uc3
    uc3 -.->|includes| uc4
    uc4 -.->|includes| uc5
    
    uc5 -->|extends| uc6 : if need correction
    uc5 -->|extends| uc4 : if regenerate
    
    uc5 -.->|includes| uc7
    uc7 -.->|includes| uc8
    
    ' System Internal - Material Reading
    uc4 -.->|includes| uc2
    uc2 -->|"if post:"| uc13
    uc2 -->|"if lesson:"| uc14
    uc13 -.->|includes| uc15
    uc14 -.->|includes| uc15
    
    ' System Internal - AI Generation
    uc15 -.->|includes| uc16
    uc16 -.->|includes| uc17
    ai -->|provides| uc17 : API response
    uc17 -.->|includes| uc18
    uc18 -.->|includes| uc19
    
    ' System Internal - Persistence
    uc19 -.->|includes| uc20
    uc20 -.->|includes| uc21
    uc20 -.->|includes| uc8
    uc21 -.->|enables| uc22
    uc22 -.->|enables| uc23
    
    ' Admin Config
    uc12 -.->|supports| uc17
    uc11 -.->|monitors| uc4
    uc9 -.->|populates| uc14
    uc10 -.->|organizes| uc14
}

note bottom of teacher
    **Guru Role:**
    - Create questions using AI
    - Share to students
    - Can use personal posts
    - Can use shared admin materials
end note

note bottom of admin
    **Admin Role:**
    - Upload curriculum materials
    - Configure system
    - Monitor usage
    - Manage access
end note

note bottom of student
    **Student Role:**
    - Answer questions
    - Submit answers
    - View results
end note

note right of uc2
    **Token Format:**
    post:ID (teacher material)
    lesson:ID (admin material)
end note

note right of uc15
    **Caching:**
    - Reduce DB queries
    - Reduce API calls
    - TTL: 1 hour
end note

note right of uc19
    **Validation:**
    - JSON structure
    - Content quality
    - Answer logic
end note

@enduml
