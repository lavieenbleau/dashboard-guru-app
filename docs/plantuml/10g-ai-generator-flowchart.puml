@startuml 10g-ai-generator-flowchart
!define BGCOLOR #FAFAFA

title Flowchart: AI Question Generator Process Flow

skinparam backgroundColor BGCOLOR
skinparam defaultFontSize 10
skinparam flowdiagram {
  BackgroundColor<<start>> #90EE90
  BackgroundColor<<end>> #FFB6C1
  BackgroundColor<<process>> #87CEEB
  BackgroundColor<<decision>> #FFE5B4
  BackgroundColor<<io>> #E6E6FA
  BackgroundColor<<error>> #FFB6C1
}

start
:Guru membuka form\nGenerate Soal;

:Select Material Source\n(post:ID atau lesson:ID);

if (Material\nvalid?) then (NO - tidak ada atau no access)
    :Show Error:\n"Material not found\nor no access";
    stop
else (YES)
    :Ambil material text\nfrom database;
    :Cache material;
endif

:Guru input:\n- Jumlah soal\n- Tingkat kesulitan\n- Tipe soal\n(MCQ/Essay);

if (Valid\ninput?) then (NO)
    :Show error messages;
    :Kembali ke form;
    stop
else (YES)
    :Prepare AI prompt;
endif

:Send request ke\nOpenAI API;

if (API\nSuccess?) then (NO - Error)
    :Check error type:
        - Rate limit?\n        - Invalid key?\n        - Timeout?;
    :Log error;
    :Show user:\n"Generation failed";
    :Offer retry;
    stop
else (YES - 200 OK)
    :Receive JSON\nresponse;
endif

:Parse response\nExtract questions;

if (Valid\nJSON?) then (NO)
    :Malformed response;
    :Log error;
    :Show:\n"Invalid format";
    stop
else (YES)
    :Validate each\nquestion;
endif

if (All questions\nvalid?) then (NO)
    :Filter invalid\nquestions;
    :Keep valid ones;
    :Notify user:\n"Some questions\nfiltered";
else (YES)
    :All good;
endif

:Store to temp cache\nfor preview;

:Send preview to\nfrontend;

:Guru review\npertanyaan;

switch (Guru action?)
case (Accept & Save)
    :Save Exercise\nwith type & serial_id;
    :Batch insert\nExerciseItems;
    :Batch insert\nExerciseItemAnswers;
    :Update Exercise\nstatus = 'published';
    :Show success message;
    :Redirect to\nBank Soal;
    
case (Edit & Save)
    :Guru edit\npertanyaan di UI;
    :Update modified\nquestions in temp;
    :Go back to\nAccept & Save;
    
case (Regenerate)
    :Clear temp data;
    :Go back to\ninput preferences;
    
case (Cancel)
    :Clear temp data;
    :Discard everything;
    :Redirect to\nmenu;
endswitch

:Pertanyaan siap\ndi Bank Soal;

:Guru bisa:\n- Share ke kelas\n- Edit individual soal\n- Delete soal\n- View analytics;

stop

@enduml
