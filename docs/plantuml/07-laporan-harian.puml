@startuml 07-laporan-harian
title Alur Laporan Harian - DashboardGuru

start

:Guru memilih aplikasi/serial;

:Lihat kalender\nlaporan harian;

:Pilih tanggal;

if (Ada data\ndi tanggal ini?) then (Tidak)
  :Tampilkan:\nTidak ada aktivitas\nsiswa pada tanggal ini;
  stop
else (Ya)
  :Load data aktivitas:\n- Tugas dikumpulkan\n- Soal dikerjakan\n- Materi diakses;
  
  :Kelompokkan data\nper kelas;
  
  partition "Tampilan Laporan" {
    :Tampilkan laporan:\n- Nama siswa\n- Aktivitas\n- Waktu\n- Status;
    
    switch (Filter?)
    case (Per Kelas)
      :Pilih kelas tertentu;
      
    case (Per Siswa)
      :Pilih siswa tertentu;
      
    case (Per Aktivitas)
      :Pilih jenis aktivitas;
      
    case (Semua)
      :Tampilkan semua;
    endswitch
  }
  
  switch (Aksi?)
  case (Export PDF)
    :Generate laporan\nformat PDF;
    :Download file PDF;
    stop
    
  case (Export Excel)
    :Generate laporan\nformat Excel;
    :Download file Excel;
    stop
    
  case (Print)
    :Print laporan;
    stop
    
  case (Lihat Detail)
    :Detail aktivitas siswa;
    
    :Tampilkan:\n- Timeline aktivitas\n- Durasi\n- Hasil kerja\n- Nilai jika ada;
    
    if (Bisa beri nilai?) then (Ya)
      :Input nilai dan feedback;
      :Simpan nilai;
      stop
    else (Tidak)
      stop
    endif
    
  case (Kembali)
    :Kembali ke kalender;
    stop
  endswitch
endif

@enduml
