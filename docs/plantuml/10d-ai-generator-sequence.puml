@startuml 10d-ai-generator-sequence
title Sequence Diagram: AI Question Generator dengan Dual-Source Material

actor Guru
participant "Browser\nFrontend" as frontend
participant "SoalController\nreadMaterials()" as controller
participant "Token Parser\n& Source Detector" as parser
participant "Database\nPost/Lesson" as db
participant "Material Processor\n& Cache" as material
participant "OpenAIService" as service
participant "OpenAI API" as openai
participant "Response Parser\n& Validator" as validator
participant "Exercise Repo\n& Storage" as storage

== 1. User Request ==
Guru -> frontend: Klik "Generate Soal dengan AI"
frontend -> frontend: Tampilkan form\nPilih sumber materi

Guru -> frontend: Pilih material\n(post:312 atau lesson:156)\nKlik Generate

frontend -> controller: POST /generate-soal\nmaterial_token=post:312

== 2. Material Resolution ==
controller -> parser: Parse token\nExtract prefix & ID

alt Token = "post:312"
    parser -> parser: Detect source: POST
    parser -> controller: Return\nsource_type='post',\nid=312
    
    controller -> db: Query Post\nwhere id=312\nAND serial_id=Guru.serial_id
    db -> db: Check ownership\n(serial_id validation)
    db -> controller: Return Post content\n"Materi Matematika kelas 3..."
    
else Token = "lesson:156"
    parser -> parser: Detect source: LESSON
    parser -> controller: Return\nsource_type='lesson',\nid=156
    
    controller -> db: Query Lesson\nwhere id=156\nAND category='materi'
    db -> controller: Return Lesson content\n"Bakteri dan Reproduksi..."
end

== 3. Material Caching ==
controller -> material: Check cache\nkey="ai_material_post:312"

alt Cached
    material -> material: Retrieve dari cache
    material -> controller: Return cached content
    note over material: (TTL: 1 jam)\nReduce DB query
else Not Cached
    controller -> material: Store new\nmaterial text
    material -> material: Cache with TTL=3600
    material -> controller: Ready to process
end

== 4. Prompt Building ==
controller -> service: Call generateQuestions(\nmaterial_content,\nquestion_count=5,\ndifficulty='medium',\ntypes=['mcq','essay'])

service -> service: Build AI Prompt Template:\n\n"Berdasarkan materi:\n{material_text}\n\nBuatkan 5 soal:\n- 3 Pilihan Ganda\n- 2 Essay\nDifficulty: Medium\nFormat: JSON"

== 5. OpenAI API Call ==
service -> openai: POST /chat/completions\n{\n  model: 'gpt-4',\n  messages: [...],\n  max_tokens: 2048,\n  temperature: 0.7\n}

note over openai: OpenAI Processing\n~15-60 detik

alt API Success (200)
    openai -> service: Return JSON Response\n{\n  "choices": [{\n    "message": {\n      "content": "{...questions...}"\n    }\n  }]\n}
    
else API Error
    openai -> service: Error Response\n(rate limit, invalid key, etc)
    service -> controller: Catch exception\n→ Return error message
    controller -> frontend: 500 Error\n"Gagal generate soal"
    frontend -> Guru: Tampilkan error UI
    Guru -> Guru: Retry atau pilih materi lain
end

== 6. Response Validation ==
service -> validator: Parse AI response

alt Valid JSON Structure
    validator -> validator: Extract questions\nValidate each item:\n- id\n- question_text\n- type (MCQ/Essay)\n- answers\n- correct_answer
    
    validator -> service: Return validated array\nof question objects
    
else Invalid Structure
    validator -> service: Log error:\n"Unexpected format"
    service -> controller: Return error\n"AI format tidak valid"
    controller -> frontend: Show error
    Guru -> frontend: Try regenerate
end

== 7. Temporary Storage ==
service -> storage: Store temp questions\nSession/Cache\nkey="ai_questions_temp_xxx"

storage -> controller: Return temp storage key\n& preview data

controller -> frontend: Return JSON:\n{\n  "preview": [questions],\n  "temp_key": "xxx"\n}

== 8. User Review & Save ==
frontend -> Guru: Display preview:\n☐ Question 1 (MCQ)\n☐ Question 2 (Essay)\n...\n\n[Edit] [Save] [Regenerate]

alt Guru klik Save
    Guru -> frontend: Klik tombol "Simpan ke Bank Soal"
    frontend -> controller: POST /save-generated\ntemp_key='xxx'
    
    controller -> storage: Retrieve temp data\nfrom cache/session
    
    controller -> storage: Create Exercise\nfor this soal batch
    
    storage -> storage: INSERT INTO exercises\n(serial_id, exercise_type_id, ...)\n→ exercise_id = 500
    
    controller -> storage: Create ExerciseItems\nfor each question\nwith exercise_id=500
    
    storage -> storage: INSERT INTO exercise_items\n(exercise_id, question, ...)\nBatch insert 5 items
    
    storage -> controller: Success\nReturned exercise_id=500
    
    controller -> frontend: Return success\n+ redirect to exercise edit
    
    frontend -> Guru: Display success message\nRedirect ke bank soal

else Guru klik Edit
    Guru -> frontend: Edit question text
    frontend -> frontend: Update preview
    
else Guru klik Regenerate
    Guru -> frontend: Click regenerate
    frontend -> frontend: Clear temp data
    frontend -> controller: Back to step 2
    note over Guru,controller: Process ulangi\ndengan material yang sama
end

== Final State ==
Guru -> frontend: Lihat bank soal
frontend -> Guru: Question batch sekarang \nada di Exercise #500\nReady untuk:\n- Share ke kelas\n- Edit pertanyaan\n- Assign ke siswa

@enduml
