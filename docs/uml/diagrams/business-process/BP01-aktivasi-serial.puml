@startuml BP01-Aktivasi-Serial

skinparam defaultTextAlignment center
skinparam activity {
  BackgroundColor White
  BorderColor Black
  FontSize 12
}

start

:Awal;

:Admin generate
serial code;

:Kirim serial code
ke guru via email/WA;

:Guru terima
serial code;

:Guru registrasi akun
di sistem;

:Input serial code
di halaman aktivasi;

:Sistem validasi
serial code;

if (Serial valid?) then (Ya)
  :Aktivasi serial;
  :Link serial
  ke akun guru;
  :Set status active
  & expired date;
  :Redirect ke
  dashboard guru;
else (Tidak)
  :Tampilkan pesan error
  "Serial tidak valid";
  stop
endif

:Guru akses
dashboard;

:Awal;

stop

@enduml
