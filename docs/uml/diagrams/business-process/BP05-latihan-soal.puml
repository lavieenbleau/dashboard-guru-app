@startuml BP05-Latihan-Soal

skinparam defaultTextAlignment center
skinparam activity {
  BackgroundColor White
  BorderColor Black
  FontSize 12
}

start

:Awal;

:Guru pilih menu
"Latihan";

:Pilih pelajaran;

:Klik "Buat
Latihan Baru";

:Input judul
& deskripsi latihan;

:Pilih tipe soal:
- Pilihan ganda
- Essay
- Benar/Salah
- Isian singkat;

repeat
  :Buat soal baru;
  
  :Input pertanyaan;
  
  if (Tipe soal?) then (Pilihan Ganda)
    :Input opsi A,B,C,D;
    :Tandai jawaban benar;
  else if (Essay) then
    :Set poin maksimal;
  else if (Benar/Salah) then
    :Pilih jawaban benar;
  else (Isian)
    :Input jawaban benar;
  endif
  
  :Set poin soal;
  
repeat while (Tambah soal lagi?) is (Ya)
->Tidak;

:Pilih kelas tujuan;

:Publish latihan;

:Sistem notifikasi
ke siswa;

:Siswa buka
daftar latihan;

:Siswa klik
"Mulai Latihan";

repeat
  :Tampilkan soal;
  :Siswa jawab soal;
repeat while (Ada soal lagi?) is (Ya)
->Tidak;

:Siswa submit
semua jawaban;

:Sistem auto-grading
(pilgan, B/S, isian);

if (Ada essay?) then (Ya)
  :Tandai untuk
  review manual guru;
  
  :Guru review
  jawaban essay;
  
  :Guru input
  nilai essay;
endif

:Hitung total nilai;

:Simpan ke
database nilai;

:Notifikasi
hasil ke siswa;

:Siswa lihat
nilai & pembahasan;

:Awal;

stop

@enduml
