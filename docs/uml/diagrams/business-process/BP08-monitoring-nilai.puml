@startuml BP08-Monitoring-Nilai

skinparam defaultTextAlignment center
skinparam activity {
  BackgroundColor White
  BorderColor Black
  FontSize 12
}

start

:Awal;

:Guru pilih menu
"Monitoring & Laporan";

:Pilih kelas
yang akan dimonitor;

:Sistem tampilkan
dashboard analytics;

:Lihat statistik:
- Jumlah siswa aktif
- Rata-rata nilai
- Tugas selesai
- Kehadiran online class;

if (Lihat detail siswa?) then (Ya)
  :Pilih siswa
  tertentu;
  
  :Tampilkan detail:
  - Riwayat nilai
  - Tugas dikerjakan
  - Latihan selesai
  - Kehadiran
  - Laporan yang dibuat;
  
  if (Performance siswa?) then (Rendah)
    :Tandai siswa
    perlu perhatian;
    :Buat catatan
    khusus;
    :Hubungi siswa/
    orang tua;
  else (Baik)
    :Berikan
    apresiasi;
  endif
endif

if (Export data?) then (Ya)
  :Pilih format:
  PDF atau Excel;
  
  :Pilih periode
  & filter data;
  
  :Generate report;
  
  :Download file;
endif

if (Lihat perbandingan kelas?) then (Ya)
  :Pilih multiple kelas;
  
  :Tampilkan grafik
  perbandingan:
  - Rata-rata nilai
  - Completion rate
  - Engagement level;
  
  :Analisis gap
  antar kelas;
endif

:Buat action plan
untuk improvement;

:Awal;

stop

@enduml
