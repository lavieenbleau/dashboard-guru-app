@startuml Business-Process-DashboardGuru-Complete

skinparam defaultTextAlignment center
skinparam activity {
  BackgroundColor White
  BorderColor Black
  FontSize 11
}

title Business Process DashboardGuru System - Complete Flow

start

:Awal;

note right
  **FASE 1: SETUP AWAL**
  Admin & Guru
end note

partition "**REGISTRASI & AKTIVASI**" {
  :Admin generate
  serial code produk;
  
  :Kirim serial ke guru
  via email/WA;
  
  :Guru registrasi akun
  di sistem;
  
  :Input serial code
  di halaman aktivasi;
  
  :Sistem validasi
  serial code;
  
  if (Serial valid?) then (Ya)
    :Aktivasi serial;
    :Link serial ke akun guru;
    :Set status active
    & expired date;
  else (Tidak)
    :Tampilkan error
    "Serial tidak valid";
    stop
  endif
}

partition "**SETUP KELAS**" {
  :Guru buat kelas baru;
  
  :Input data kelas:
  - Nama kelas
  - Tingkat/Grade;
  
  :Sistem generate
  kode kelas unik;
  
  :Simpan data kelas;
  
  :Guru bagikan kode kelas
  ke siswa;
  
  :Siswa registrasi
  dengan kode kelas;
  
  :Sistem validasi
  kode kelas;
  
  if (Kode valid?) then (Ya)
    :Link siswa ke kelas;
    :Buat akun siswa;
    :Generate username
    & password;
  else (Tidak)
    :Tampilkan error
    "Kode kelas salah";
    stop
  endif
}

note right
  **FASE 2: PEMBELAJARAN**
  Guru & Siswa
end note

fork
  partition "**MATERI PELAJARAN**" {
    :Guru buat pelajaran baru;
    
    :Pilih mata pelajaran;
    
    :Input data pelajaran:
    - Nama
    - Tingkat & semester
    - Kategori;
    
    if (Gunakan tema?) then (Ya)
      :Buat tema & subtema;
    endif
    
    :Tambah item materi;
    
    if (Tipe konten?) then (Video)
      :Input embed video;
    else if (File) then
      :Upload file;
    else if (Link) then
      :Input URL link;
    else (Teks)
      :Input deskripsi;
    endif
    
    :Pilih kelas tujuan
    (bisa multiple);
    
    :Publish materi;
    
    :Sistem notifikasi siswa;
    
    :Siswa akses & baca materi;
  }

fork again
  partition "**TUGAS**" {
    :Guru buat tugas baru;
    
    :Input data tugas:
    - Judul
    - Deskripsi
    - Deadline;
    
    if (Ada file instruksi?) then (Ya)
      :Upload file lampiran;
    endif
    
    :Set flag "Adalah Tugas";
    
    :Pilih kelas tujuan;
    
    :Publish tugas;
    
    :Sistem notifikasi siswa;
    
    :Siswa baca instruksi;
    
    :Siswa kerjakan tugas;
    
    :Upload file jawaban;
    
    :Submit tugas;
    
    :Sistem notifikasi guru;
    
    :Guru review jawaban;
    
    :Input nilai & feedback;
    
    :Simpan penilaian;
    
    :Sistem notifikasi
    nilai ke siswa;
  }

fork again
  partition "**LATIHAN/EXERCISE**" {
    :Guru buat latihan baru;
    
    :Input judul & deskripsi;
    
    :Pilih tipe soal:
    - Pilihan ganda
    - Essay
    - Benar/Salah
    - Isian singkat;
    
    repeat
      :Buat soal baru;
      :Input pertanyaan;
      :Set jawaban & poin;
    repeat while (Tambah soal?) is (Ya)
    ->Tidak;
    
    :Pilih kelas tujuan;
    
    :Publish latihan;
    
    :Sistem notifikasi siswa;
    
    :Siswa klik "Mulai Latihan";
    
    repeat
      :Siswa jawab soal;
    repeat while (Ada soal lagi?) is (Ya)
    ->Tidak;
    
    :Submit jawaban;
    
    :Sistem auto-grading
    (pilgan, B/S, isian);
    
    if (Ada essay?) then (Ya)
      :Guru review manual;
      :Input nilai essay;
    endif
    
    :Hitung total nilai;
    
    :Simpan ke database;
    
    :Notifikasi hasil ke siswa;
  }

fork again
  partition "**KELAS ONLINE**" {
    :Guru jadwalkan
    pertemuan online;
    
    :Input data:
    - Judul
    - Tanggal & waktu
    - Durasi;
    
    :Sistem generate
    room name Jitsi;
    
    :Pilih kelas/siswa;
    
    :Simpan jadwal;
    
    :Sistem notifikasi siswa;
    
    if (Waktu dimulai?) then (Sudah)
      :Guru mulai pertemuan;
      
      :Sistem buka Jitsi Meeting;
      
      :Guru join room;
      
      :Siswa join room;
      
      :Pembelajaran online
      berlangsung;
      
      :Guru share screen
      & presentasi;
      
      :Interaksi guru & siswa;
      
      if (Selesai?) then (Ya)
        :Guru end meeting;
        :Record attendance;
        :Set status completed;
      endif
    else (Belum)
      :Tunggu waktu dijadwalkan;
    endif
  }

fork again
  partition "**LAPORAN SISWA**" {
    :Siswa buat laporan;
    
    :Tulis isi laporan:
    - Kendala belajar
    - Feedback
    - Pertanyaan;
    
    if (Ada bukti?) then (Ya)
      :Upload gambar;
    endif
    
    :Submit laporan;
    
    :Sistem notifikasi guru;
    
    :Guru baca laporan;
    
    if (Perlu tindak lanjut?) then (Ya)
      :Guru hubungi siswa;
      :Berikan solusi/feedback;
      :Catat tindakan;
    else (Tidak)
      :Tandai sudah dibaca;
    endif
    
    :Update status laporan;
  }
end fork

note right
  **FASE 3: MONITORING**
  Guru & Admin
end note

partition "**MONITORING & ANALYTICS**" {
  :Guru pilih menu
  "Monitoring & Laporan";
  
  :Pilih kelas
  untuk dimonitor;
  
  :Sistem tampilkan
  dashboard analytics:
  - Jumlah siswa aktif
  - Rata-rata nilai
  - Tugas selesai
  - Kehadiran
  - Engagement level;
  
  if (Lihat detail siswa?) then (Ya)
    :Pilih siswa tertentu;
    
    :Tampilkan riwayat:
    - Nilai semua tugas
    - Latihan selesai
    - Kehadiran online class
    - Laporan dibuat;
    
    if (Performance rendah?) then (Ya)
      :Tandai siswa
      perlu perhatian;
      :Buat catatan khusus;
      :Hubungi siswa/ortu;
    else (Baik)
      :Berikan apresiasi;
    endif
  endif
  
  if (Export data?) then (Ya)
    :Pilih format
    (PDF/Excel);
    
    :Pilih periode
    & filter data;
    
    :Generate report;
    
    :Download file;
  endif
  
  if (Lihat perbandingan?) then (Ya)
    :Pilih multiple kelas;
    
    :Tampilkan grafik
    perbandingan;
    
    :Analisis gap
    antar kelas;
  endif
  
  :Buat action plan
  untuk improvement;
}

note right
  **FASE 4: EVALUASI**
  Periodic Review
end note

partition "**EVALUASI & RENEWAL**" {
  :Guru review
  laporan bulanan;
  
  :Evaluasi efektivitas
  pembelajaran;
  
  :Identifikasi area
  yang perlu perbaikan;
  
  if (Serial akan expired?) then (Ya)
    :Notifikasi ke guru;
    
    :Hubungi admin
    untuk renewal;
    
    :Admin generate
    serial baru;
    
    :Guru aktivasi
    serial baru;
  endif
  
  :Lanjut ke periode
  pembelajaran berikutnya;
}

:Awal;

stop

legend right
  **LEGENDA:**
  |= Aktor |= Peran |
  | Admin/Sales | Generate & manage serial |
  | Guru | Create content & manage class |
  | Siswa | Learn & submit work |
  | Sistem | Auto-process & notify |
  
  **FITUR UTAMA:**
  ✓ Multi-class management
  ✓ Various content types
  ✓ Auto-grading system
  ✓ Online meeting integration
  ✓ Real-time analytics
  ✓ Comprehensive reporting
endlegend

@enduml
