@startuml BP06-Kelas-Online

skinparam defaultTextAlignment center
skinparam activity {
  BackgroundColor White
  BorderColor Black
  FontSize 12
}

start

:Awal;

:Guru pilih menu
"Kelas Online";

:Klik "Jadwalkan
Pertemuan Baru";

:Input data:
- Judul pertemuan
- Tanggal & waktu
- Durasi (menit);

:Sistem generate
room name Jitsi;

:Pilih kelas/siswa
yang ikut;

:Simpan jadwal;

:Sistem notifikasi
ke siswa;

:Siswa lihat
jadwal kelas online;

if (Waktu dimulai?) then (Belum)
  :Tunggu waktu
  yang dijadwalkan;
else (Sudah)
  :Guru klik
  "Mulai Pertemuan";
endif

:Sistem buka
Jitsi Meeting;

:Set room name
& display name;

:Guru join room;

:Tunggu siswa
join;

:Siswa klik
"Join Pertemuan";

if (Siswa valid?) then (Ya)
  :Siswa join room;
  :Aktifkan kamera
  & mic (opsional);
else (Tidak)
  :Tampilkan error
  akses ditolak;
  stop
endif

:Pembelajaran online
berlangsung;

:Guru share screen
presentasi materi;

:Interaksi guru
& siswa (chat/voice);

if (Selesai?) then (Ya)
  :Guru end meeting;
  :Sistem tutup room;
  :Record attendance;
  :Set status completed;
else (Tidak)
  :Lanjut pembelajaran;
endif

:Awal;

stop

@enduml
