@startuml SystemArchitecture

!define RECTANGLE class

skinparam component {
  BackgroundColor<<presentation>> LightBlue
  BackgroundColor<<application>> LightGreen
  BackgroundColor<<domain>> LightYellow
  BackgroundColor<<infrastructure>> LightGray
  BackgroundColor<<external>> LightPink
}

package "Presentation Layer" {
  [Blade Templates] <<presentation>>
  [Layouts] <<presentation>>
  [Components] <<presentation>>
  
  package "Views" {
    [Guru Views] <<presentation>>
    [Rekap Nilai Views] <<presentation>>
    [Kelas Views] <<presentation>>
    [Materi Views] <<presentation>>
    [Soal Views] <<presentation>>
  }
}

package "Application Layer" {
  package "Controllers" {
    [AplikasiController] <<application>>
    [KelasController] <<application>>
    [MateriController] <<application>>
    [SoalController] <<application>>
    [TugasController] <<application>>
    [RekapNilaiController] <<application>>
    [PengaturanController] <<application>>
  }
  
  package "Middleware" {
    [Authenticate] <<application>>
    [VerifyCsrfToken] <<application>>
    [TrimStrings] <<application>>
  }
  
  package "Requests" {
    [Validation Rules] <<application>>
  }
}

package "Domain Layer" {
  package "Models (Eloquent)" {
    [User] <<domain>>
    [Serial] <<domain>>
    [Product] <<domain>>
    [Classroom] <<domain>>
    [Student] <<domain>>
    [Lesson] <<domain>>
    [Exercise] <<domain>>
    [Post] <<domain>>
    [Task] <<domain>>
    [ExercisePoint] <<domain>>
    [Mapel] <<domain>>
  }
  
  package "Business Logic" {
    [Sharing Logic] <<domain>>
    [Grading Logic] <<domain>>
    [Import/Export Logic] <<domain>>
  }
}

package "Infrastructure Layer" {
  [Database (MySQL)] <<infrastructure>>
  [File Storage] <<infrastructure>>
  [Session Management] <<infrastructure>>
  [Cache] <<infrastructure>>
  
  package "External Services" {
    [DomPDF Library] <<external>>
    [Laravel Framework] <<external>>
    [Composer Packages] <<external>>
  }
}

package "Routes" {
  [web.php] <<application>>
  [auth.php] <<application>>
}

' Relationships - Presentation to Application
[Blade Templates] --> [Controllers]
[Guru Views] --> [Controllers]
[Rekap Nilai Views] --> [RekapNilaiController]
[Kelas Views] --> [KelasController]
[Materi Views] --> [MateriController]
[Soal Views] --> [SoalController]

' Relationships - Application to Domain
[Controllers] --> [Models (Eloquent)]
[KelasController] --> [Classroom]
[KelasController] --> [Student]
[MateriController] --> [Lesson]
[SoalController] --> [Exercise]
[RekapNilaiController] --> [Task]
[RekapNilaiController] --> [ExercisePoint]

[Controllers] --> [Business Logic]
[Business Logic] --> [Models (Eloquent)]

' Relationships - Domain to Infrastructure
[Models (Eloquent)] --> [Database (MySQL)]
[Models (Eloquent)] --> [File Storage]

' Relationships - Infrastructure
[Controllers] --> [DomPDF Library]
[Controllers] --> [Session Management]
[Models (Eloquent)] --> [Laravel Framework]

' Middleware flow
[Routes] --> [Middleware]
[Middleware] --> [Controllers]

' Request flow
Browser --> [Routes] : HTTP Request
[Routes] --> [Middleware]
[Middleware] --> [Controllers]
[Controllers] --> [Models (Eloquent)]
[Models (Eloquent)] --> [Database (MySQL)]

note right of [DomPDF Library]
  Used for generating
  PDF reports for
  grade recap
end note

note right of [Database (MySQL)]
  Stores all application
  data including:
  - Users & Students
  - Lessons & Exercises
  - Tasks & Grades
  - Sharing configurations
end note

@enduml
