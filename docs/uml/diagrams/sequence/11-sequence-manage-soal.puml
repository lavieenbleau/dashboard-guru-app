@startuml ManageSoal-Sequence
!theme plain
scale 0.75
skinparam dpi 150
title Sequence Diagram: Manage Soal (CRUD Exercises)

actor "Guru" as Guru
control ":SoalController" as Controller <<control>>
entity ":Serial" as Serial <<entity>>
entity ":Lesson" as Lesson <<entity>>
entity ":Exercise" as Exercise <<entity>>
entity ":ExerciseItem" as ExerciseItem <<entity>>
control ":Storage" as Storage <<control>>
database ":Database" as DB

== List Soal by Tema ==
Guru -> Controller: Lihat Daftar Soal
activate Controller

Controller -> Serial: Ambil Data Serial
activate Serial
Serial -> DB: Retrieve
activate DB
DB --> Serial: Data
deactivate DB
Serial --> Controller: Data Serial
deactivate Serial

Controller -> Lesson: Ambil Lessons & Exercises
activate Lesson
Lesson -> DB: Retrieve with Relations
activate DB
DB --> Lesson: Data
deactivate DB
Lesson --> Controller: List Lessons & Exercises
deactivate Lesson

Controller --> Guru: Tampilkan Daftar Soal
deactivate Controller

== Create Soal ==
Guru -> Controller: Buat Soal Baru
activate Controller

Controller -> Controller: Validasi Input

alt Validasi Gagal
  Controller --> Guru: Tampilkan Error
else Validasi Berhasil
  
  Controller -> Exercise: Simpan Exercise
  activate Exercise
  Exercise -> DB: Save
  activate DB
  DB --> Exercise: Saved
  deactivate DB
  Exercise --> Controller: Exercise Tersimpan
  deactivate Exercise
  
  loop Untuk Setiap Item Soal
    
    alt Item Ada Gambar
      Controller -> Storage: Upload Gambar
      activate Storage
      Storage --> Controller: Path Gambar
      deactivate Storage
    end
    
    Controller -> ExerciseItem: Simpan Item Soal
    activate ExerciseItem
    ExerciseItem -> DB: Save
    activate DB
    DB --> ExerciseItem: Saved
    deactivate DB
    ExerciseItem --> Controller: Item Tersimpan
    deactivate ExerciseItem
  end
  
  Controller --> Guru: Konfirmasi Berhasil
end

deactivate Controller

== Update Soal ==
Guru -> Controller: Edit Soal
activate Controller

Controller -> Controller: Validasi Input

alt Validasi Gagal
  Controller --> Guru: Tampilkan Error
else Validasi Berhasil
  
  Controller -> Exercise: Cari Exercise
  activate Exercise
  Exercise -> DB: Retrieve
  activate DB
  DB --> Exercise: Data
  deactivate DB
  Exercise --> Controller: Data Exercise
  deactivate Exercise
  
  Controller -> Exercise: Update Exercise
  activate Exercise
  Exercise -> DB: Update
  activate DB
  DB --> Exercise: Updated
  deactivate DB
  Exercise --> Controller: Exercise Terupdate
  deactivate Exercise
  
  Controller -> ExerciseItem: Hapus Item Lama
  activate ExerciseItem
  ExerciseItem -> DB: Delete
  activate DB
  DB --> ExerciseItem: Deleted
  deactivate DB
  ExerciseItem --> Controller: Item Terhapus
  deactivate ExerciseItem
  
  loop Untuk Setiap Item Baru
    alt Item Ada Gambar
      Controller -> Storage: Upload Gambar
      activate Storage
      Storage --> Controller: Path Gambar
      deactivate Storage
    end
    
    Controller -> ExerciseItem: Simpan Item Baru
    activate ExerciseItem
    ExerciseItem -> DB: Save
    activate DB
    DB --> ExerciseItem: Saved
    deactivate DB
    ExerciseItem --> Controller: Item Tersimpan
    deactivate ExerciseItem
  end
  
  Controller --> Guru: Konfirmasi Berhasil
end

deactivate Controller

== Delete Soal ==
Guru -> Controller: Hapus Soal
activate Controller

Controller -> Exercise: Cari Exercise
activate Exercise
Exercise -> DB: Retrieve
activate DB
DB --> Exercise: Data
deactivate DB
Exercise --> Controller: Data Exercise
deactivate Exercise

Controller -> Exercise: Hapus Exercise
activate Exercise
Exercise -> DB: Delete
activate DB
DB --> Exercise: Deleted
deactivate DB
Exercise --> Controller: Exercise Terhapus
deactivate Exercise

Controller --> Guru: Konfirmasi Penghapusan

deactivate Controller

@enduml
