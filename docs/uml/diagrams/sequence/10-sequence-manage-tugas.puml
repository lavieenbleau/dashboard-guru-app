@startuml ManageTugas-Sequence
!theme plain
scale 0.75
skinparam dpi 150
title Sequence Diagram: Manage Tugas (CRUD Tasks/Posts)

actor "Guru" as Guru
control ":TugasController" as Controller <<control>>
entity ":Serial" as Serial <<entity>>
entity ":Mapel" as Mapel <<entity>>
entity ":Post" as Post <<entity>>
control ":Storage" as Storage <<control>>
database ":Database" as DB

== List Tugas by Mapel ==
Guru -> Controller: Lihat Daftar Tugas
activate Controller

Controller -> Serial: Ambil Data Serial
activate Serial
Serial -> DB: Retrieve
activate DB
DB --> Serial: Data
deactivate DB
Serial --> Controller: Data Serial
deactivate Serial

Controller -> Mapel: Ambil Data Mapel
activate Mapel
Mapel -> DB: Retrieve
activate DB
DB --> Mapel: Data
deactivate DB
Mapel --> Controller: Data Mapel
deactivate Mapel

Controller -> Post: Ambil Semua Tugas
activate Post
Post -> DB: Retrieve
activate DB
DB --> Post: Data
deactivate DB
Post --> Controller: List Tugas
deactivate Post

Controller --> Guru: Tampilkan Daftar Tugas
deactivate Controller

== Create Tugas ==
Guru -> Controller: Buat Tugas Baru
activate Controller

Controller -> Controller: Validasi Input

alt Validasi Gagal
  Controller --> Guru: Tampilkan Error
else Validasi Berhasil
  
  alt Ada File Dilampirkan
    Controller -> Storage: Upload File
    activate Storage
    Storage --> Controller: Path File
    deactivate Storage
  end
  
  Controller -> Post: Simpan Tugas
  activate Post
  Post -> DB: Save
  activate DB
  DB --> Post: Saved
  deactivate DB
  Post --> Controller: Tugas Tersimpan
  deactivate Post
  
  Controller --> Guru: Konfirmasi Berhasil
end

deactivate Controller

== Update Tugas ==
Guru -> Controller: Edit Tugas
activate Controller

Controller -> Controller: Validasi Input

alt Validasi Gagal
  Controller --> Guru: Tampilkan Error
else Validasi Berhasil
  
  Controller -> Post: Cari Tugas
  activate Post
  Post -> DB: Retrieve
  activate DB
  DB --> Post: Data
  deactivate DB
  Post --> Controller: Data Tugas
  deactivate Post
  
  alt Ada File Baru
    Controller -> Storage: Hapus File Lama & Upload Baru
    activate Storage
    Storage --> Controller: Path File Baru
    deactivate Storage
  end
  
  Controller -> Post: Update Tugas
  activate Post
  Post -> DB: Update
  activate DB
  DB --> Post: Updated
  deactivate DB
  Post --> Controller: Tugas Terupdate
  deactivate Post
  
  Controller --> Guru: Konfirmasi Berhasil
end

deactivate Controller

== Delete Tugas ==
Guru -> Controller: Hapus Tugas
activate Controller

Controller -> Post: Cari Tugas
activate Post
Post -> DB: Retrieve
activate DB
DB --> Post: Data
deactivate DB
Post --> Controller: Data Tugas
deactivate Post

alt Ada File Terlampir
  Controller -> Storage: Hapus File
  activate Storage
  Storage --> Controller: File Terhapus
  deactivate Storage
end

Controller -> Post: Hapus Tugas
activate Post
Post -> DB: Delete
activate DB
DB --> Post: Deleted
deactivate DB
Post --> Controller: Tugas Terhapus
deactivate Post

Controller --> Guru: Konfirmasi Penghapusan

deactivate Controller

@enduml
