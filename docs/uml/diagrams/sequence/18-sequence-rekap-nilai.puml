@startuml RekapNilai-Sequence
!theme plain
scale 0.75
skinparam dpi 150
title Sequence Diagram: Rekap Nilai Detail per Mata Pelajaran

actor "Guru" as Guru
control ":RekapNilaiController" as Controller <<control>>
entity ":Serial" as Serial <<entity>>
entity ":Classroom" as Classroom <<entity>>
entity ":Student" as Student <<entity>>
entity ":Mapel" as Mapel <<entity>>
entity ":Post" as Post <<entity>>
entity ":Exercise" as Exercise <<entity>>
entity ":Task" as Task <<entity>>
entity ":ExercisePoint" as ExercisePoint <<entity>>
database ":Database" as DB

== Pilih Kelas untuk Rekap ==
Guru -> Controller: Akses Rekap Nilai
activate Controller

Controller -> Serial: Ambil Data Serial
activate Serial
Serial -> DB: Retrieve
activate DB
DB --> Serial: Data
deactivate DB
Serial --> Controller: Data Serial
deactivate Serial

Controller -> Classroom: Ambil Semua Kelas
activate Classroom
Classroom -> DB: Retrieve by Serial
activate DB
DB --> Classroom: Data
deactivate DB
Classroom --> Controller: List Kelas
deactivate Classroom

Controller --> Guru: Tampilkan List Kelas
deactivate Controller

== Lihat Rekap Nilai Kelas ==
Guru -> Controller: Pilih Kelas
activate Controller

Controller -> Student: Ambil Semua Siswa
activate Student
Student -> DB: Retrieve by Classroom
activate DB
DB --> Student: Data
deactivate DB
Student --> Controller: List Siswa
deactivate Student

Controller -> Mapel: Ambil Semua Mapel
activate Mapel
Mapel -> DB: Retrieve
activate DB
DB --> Mapel: Data
deactivate DB
Mapel --> Controller: List Mapel
deactivate Mapel

loop Untuk Setiap Mapel
  Controller -> Post: Ambil Semua Tugas (Posts)
  activate Post
  Post -> DB: Retrieve (is_task=1, mapel_id)
  activate DB
  DB --> Post: Data
  deactivate DB
  Post --> Controller: List Tugas per Mapel
  deactivate Post
  
  Controller -> Exercise: Ambil Semua Soal
  activate Exercise
  Exercise -> DB: Retrieve by Lesson (category=3)
  activate DB
  DB --> Exercise: Data
  deactivate DB
  Exercise --> Controller: List Soal per Mapel (UH, PTS, PAS)
  deactivate Exercise
end

loop Untuk Setiap Siswa
  loop Untuk Setiap Mapel
    Controller -> Task: Ambil Nilai Tugas
    activate Task
    Task -> DB: Retrieve (student_id, post_id)
    activate DB
    DB --> Task: Nilai Tugas
    deactivate DB
    Task --> Controller: Data Nilai Tugas
    deactivate Task
    
    Controller -> ExercisePoint: Ambil Nilai Soal
    activate ExercisePoint
    ExercisePoint -> DB: Retrieve (student_id, exercise_id)
    activate DB
    DB --> ExercisePoint: Nilai Soal
    deactivate DB
    ExercisePoint --> Controller: Data Nilai Soal
    deactivate ExercisePoint
    
    Controller -> Controller: Hitung Rata-rata per Mapel
  end
end

Controller --> Guru: Tampilkan Tabel Rekap (per Mapel, Detail Tugas & Soal)
deactivate Controller

== Download PDF ==
Guru -> Controller: Klik Download PDF
activate Controller

Controller -> Controller: Generate Data yang Sama

Controller -> Controller: Render PDF Template

Controller --> Guru: Download File PDF
deactivate Controller

@enduml
