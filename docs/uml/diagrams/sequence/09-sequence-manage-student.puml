@startuml ManageStudent-Sequence
!theme plain
scale 0.75
skinparam dpi 150
title Sequence Diagram: Manage Siswa (CRUD Student)

actor "Guru" as Guru
control ":KelasController" as Controller <<control>>
entity ":Classroom" as Classroom <<entity>>
entity ":Student" as Student <<entity>>
database ":Database" as DB

== Create Student Manual ==
Guru -> Controller: Tambah Siswa Baru
activate Controller

Controller -> Controller: Validasi Input

alt Validasi Gagal
  Controller --> Guru: Tampilkan Error
else Validasi Berhasil
  
  Controller -> Classroom: Cari Kelas
  activate Classroom
  Classroom -> DB: Retrieve
  activate DB
  DB --> Classroom: Data
  deactivate DB
  Classroom --> Controller: Data Kelas
  deactivate Classroom
  
  Controller -> Student: Simpan Siswa Baru
  activate Student
  Student -> DB: Save
  activate DB
  DB --> Student: Saved
  deactivate DB
  Student --> Controller: Siswa Tersimpan
  deactivate Student
  
  Controller --> Guru: Konfirmasi Berhasil
end

deactivate Controller

== Delete Student ==
Guru -> Controller: Hapus Siswa
activate Controller

Controller -> Student: Cari Siswa
activate Student
Student -> DB: Retrieve
activate DB
DB --> Student: Data
deactivate DB
Student --> Controller: Data Siswa
deactivate Student

Controller -> Student: Hapus Siswa
activate Student
Student -> DB: Delete
activate DB
DB --> Student: Deleted
deactivate DB
Student --> Controller: Siswa Terhapus
deactivate Student

Controller --> Guru: Konfirmasi Penghapusan

deactivate Controller

== Update Student ==
Guru -> Controller: Update Data Siswa
activate Controller

Controller -> Controller: Validasi Input

alt Validasi Gagal
  Controller --> Guru: Tampilkan Error
else Validasi Berhasil
  
  Controller -> Student: Cari Siswa
  activate Student
  Student -> DB: Retrieve
  activate DB
  DB --> Student: Data
  deactivate DB
  Student --> Controller: Data Siswa
  deactivate Student
  
  Controller -> Student: Update Data
  activate Student
  Student -> DB: Update
  activate DB
  DB --> Student: Updated
  deactivate DB
  Student --> Controller: Data Terupdate
  deactivate Student
  
  Controller --> Guru: Konfirmasi Berhasil
end

deactivate Controller

@enduml
