@startuml OnlineMeeting-Sequence
!theme plain
scale 0.75
skinparam dpi 150
title Sequence Diagram: Kelas Online dengan Jitsi Meet

actor "Guru" as Guru
control ":OnlineMeetingController" as Controller <<control>>
entity ":Serial" as Serial <<entity>>
entity ":OnlineMeeting" as Meeting <<entity>>
entity ":Classroom" as Classroom <<entity>>
control ":JitsiService" as Jitsi <<control>>
database ":Database" as DB

== Quick Start Meeting ==
Guru -> Controller: Mulai Meeting Cepat
activate Controller

Controller -> Controller: Validasi Input

alt Validasi Gagal
  Controller --> Guru: Tampilkan Error
else Validasi Berhasil
  
  Controller -> Controller: Generate Room Name
  
  Controller -> Meeting: Simpan Meeting
  activate Meeting
  Meeting -> DB: Save
  activate DB
  DB --> Meeting: Saved
  deactivate DB
  Meeting --> Controller: Meeting Tersimpan
  deactivate Meeting
  
  Controller -> Jitsi: Generate Join URL
  activate Jitsi
  Jitsi --> Controller: Jitsi URL with JWT
  deactivate Jitsi
  
  Controller --> Guru: Redirect ke Meeting Room
end

deactivate Controller

== Create Scheduled Meeting ==
Guru -> Controller: Jadwalkan Meeting
activate Controller

Controller -> Controller: Validasi Input

alt Validasi Gagal
  Controller --> Guru: Tampilkan Error
else Validasi Berhasil
  
  Controller -> Controller: Generate Room Name
  
  Controller -> Meeting: Simpan Scheduled Meeting
  activate Meeting
  Meeting -> DB: Save
  activate DB
  DB --> Meeting: Saved
  deactivate DB
  Meeting --> Controller: Meeting Terjadwal
  deactivate Meeting
  
  Controller --> Guru: Konfirmasi Meeting Dijadwalkan
end

deactivate Controller

== Join Meeting ==
Guru -> Controller: Join Meeting
activate Controller

Controller -> Meeting: Cari Meeting
activate Meeting
Meeting -> DB: Retrieve
activate DB
DB --> Meeting: Data
deactivate DB
Meeting --> Controller: Data Meeting
deactivate Meeting

alt Meeting Belum Dimulai
  Controller --> Guru: Error: Meeting Belum Dimulai
else Meeting Aktif
  
  Controller -> Jitsi: Generate Join URL
  activate Jitsi
  Jitsi --> Controller: Jitsi URL
  deactivate Jitsi
  
  Controller --> Guru: Redirect ke Jitsi Room
end

deactivate Controller

== End Meeting ==
Guru -> Controller: Akhiri Meeting
activate Controller

Controller -> Meeting: Cari Meeting
activate Meeting
Meeting -> DB: Retrieve
activate DB
DB --> Meeting: Data
deactivate DB
Meeting --> Controller: Data Meeting
deactivate Meeting

Controller -> Meeting: Update Status ke Ended
activate Meeting
Meeting -> DB: Update
activate DB
DB --> Meeting: Updated
deactivate DB
Meeting --> Controller: Meeting Berakhir
deactivate Meeting

Controller --> Guru: Konfirmasi Meeting Berakhir

deactivate Controller

@enduml
