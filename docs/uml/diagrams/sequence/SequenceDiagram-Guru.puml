@startuml SequenceDiagram-Guru
!theme plain
scale 0.75
skinparam dpi 150
title Sequence Diagram - Dashboard Guru\n(Proses Pembelajaran & Laporan)

actor Guru
participant "Sistem\nDashboard" as System
participant "Manajemen\nKelas" as Class
participant "Manajemen\nKonten" as Content
participant "Kelas\nOnline" as Online
participant "Laporan\nSiswa" as Report

== Proses Pembelajaran ==

Guru -> System: Login
activate System
System --> Guru: Dashboard

Guru -> System: Aktivasi Serial
System -> System: Validasi Serial
System --> Guru: Serial Aktif

Guru -> Class: Buat Kelas Baru
activate Class
Class -> Class: Simpan Data Kelas
Class --> Guru: Kelas Berhasil Dibuat
deactivate Class

alt Upload Materi
    Guru -> Content: Upload Materi Pembelajaran
    activate Content
    Content -> Content: Simpan Materi
    Content --> Guru: Materi Tersimpan
    deactivate Content
else Buat Tugas
    Guru -> Content: Buat Tugas
    activate Content
    Content -> Content: Simpan Tugas
    Content --> Guru: Tugas Tersimpan
    deactivate Content
else Buat Latihan
    Guru -> Content: Buat Latihan/Exercise
    activate Content
    Content -> Content: Simpan Latihan
    Content --> Guru: Latihan Tersimpan
    deactivate Content
end

Guru -> Online: Mulai Kelas Online
activate Online
Online -> Online: Generate Link Meeting
Online --> Guru: Link Kelas Online
Guru -> Online: Kelola Kelas Online
Online --> Guru: Kelas Berlangsung
deactivate Online

== Proses Laporan ==

Guru -> Report: Buka Laporan Siswa
activate Report
Report -> Report: Ambil Data Laporan
Report --> Guru: Tampilkan Laporan

Guru -> Report: Monitor Aktivitas Siswa
Report -> Report: Analisis Data Siswa
Report --> Guru: Data Monitoring

Guru -> Report: Beri Nilai & Feedback
Report -> Report: Simpan Penilaian
Report --> Guru: Penilaian Tersimpan

Guru -> Report: Export Laporan
Report -> Report: Generate File Export
Report --> Guru: File Laporan (Excel/PDF)
deactivate Report

deactivate System

@enduml
