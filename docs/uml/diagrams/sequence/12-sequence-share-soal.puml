@startuml ShareSoal-Sequence
!theme plain
scale 0.75
skinparam dpi 150
title Sequence Diagram: Share Soal ke Kelas (Single & Bulk)

actor "Guru" as Guru
control ":SoalController" as Controller <<control>>
entity ":Exercise" as Exercise <<entity>>
entity ":Classroom" as Classroom <<entity>>
entity ":LessonItem" as LessonItem <<entity>>
entity ":Student" as Student <<entity>>
entity ":ExercisePoint" as ExercisePoint <<entity>>
database ":Database" as DB

== Share Single Soal ==
Guru -> Controller: Share Soal ke Kelas
activate Controller

Controller -> Controller: Validasi Input

alt Validasi Gagal
  Controller --> Guru: Tampilkan Error
else Validasi Berhasil
  
  Controller -> Exercise: Ambil Data Exercise
  activate Exercise
  Exercise -> DB: Retrieve
  activate DB
  DB --> Exercise: Data
  deactivate DB
  Exercise --> Controller: Data Exercise
  deactivate Exercise
  
  loop Untuk Setiap Kelas
    
    Controller -> Classroom: Cari Kelas
    activate Classroom
    Classroom -> DB: Retrieve
    activate DB
    DB --> Classroom: Data
    deactivate DB
    Classroom --> Controller: Data Kelas
    deactivate Classroom
    
    Controller -> LessonItem: Cek Sudah Dibagikan
    activate LessonItem
    LessonItem -> DB: Check
    activate DB
    DB --> LessonItem: Status
    deactivate DB
    LessonItem --> Controller: Status Share
    deactivate LessonItem
    
    alt Belum Dibagikan
      
      Controller -> LessonItem: Simpan Share ke Kelas
      activate LessonItem
      LessonItem -> DB: Save
      activate DB
      DB --> LessonItem: Saved
      deactivate DB
      LessonItem --> Controller: Share Tersimpan
      deactivate LessonItem
      
      Controller -> Student: Ambil Semua Siswa
      activate Student
      Student -> DB: Retrieve
      activate DB
      DB --> Student: Data
      deactivate DB
      Student --> Controller: List Siswa
      deactivate Student
      
      loop Untuk Setiap Siswa
        Controller -> ExercisePoint: Buat Point Entry
        activate ExercisePoint
        ExercisePoint -> DB: Save
        activate DB
        DB --> ExercisePoint: Saved
        deactivate DB
        ExercisePoint --> Controller: Point Created
        deactivate ExercisePoint
      end
    end
  end
  
  Controller --> Guru: Konfirmasi Berhasil
end

deactivate Controller

== Bulk Share Soal ==
Guru -> Controller: Share Multiple Soal
activate Controller

Controller -> Controller: Validasi Input

alt Validasi Gagal
  Controller --> Guru: Tampilkan Error
else Validasi Berhasil
  
  loop Untuk Setiap Exercise
    
    Controller -> Exercise: Ambil Exercise
    activate Exercise
    Exercise -> DB: Retrieve
    activate DB
    DB --> Exercise: Data
    deactivate DB
    Exercise --> Controller: Data Exercise
    deactivate Exercise
    
    loop Untuk Setiap Kelas
      
      Controller -> LessonItem: Cek & Simpan Share
      activate LessonItem
      LessonItem -> DB: Save
      activate DB
      DB --> LessonItem: Saved
      deactivate DB
      LessonItem --> Controller: Share Tersimpan
      deactivate LessonItem
      
      Controller -> Student: Ambil Siswa
      activate Student
      Student -> DB: Retrieve
      activate DB
      DB --> Student: Data
      deactivate DB
      Student --> Controller: List Siswa
      deactivate Student
      
      loop Untuk Setiap Siswa
        Controller -> ExercisePoint: Buat Point Entry
        activate ExercisePoint
        ExercisePoint -> DB: Save
        activate DB
        DB --> ExercisePoint: Saved
        deactivate DB
        ExercisePoint --> Controller: Point Created
        deactivate ExercisePoint
      end
    end
  end
  
  Controller --> Guru: Konfirmasi Bulk Share Berhasil
end

deactivate Controller

@enduml
