@startuml Grading-Sequence
!theme plain
scale 0.75
skinparam dpi 150
title Sequence Diagram: Penilaian Tugas dan Soal

actor "Guru" as Guru
control ":LaporanHarianController" as LaporanController <<control>>
control ":SoalController" as SoalController <<control>>
entity ":Task" as Task <<entity>>
entity ":ExercisePoint" as ExercisePoint <<entity>>
database ":Database" as DB

== Grade Tugas (Manual) ==
Guru -> LaporanController: Beri Nilai Tugas
activate LaporanController

LaporanController -> LaporanController: Validasi Input

alt Validasi Gagal
  LaporanController --> Guru: Tampilkan Error
else Validasi Berhasil
  
  LaporanController -> Task: Cari Task
  activate Task
  Task -> DB: Retrieve
  activate DB
  DB --> Task: Data
  deactivate DB
  Task --> LaporanController: Data Task
  deactivate Task
  
  LaporanController -> Task: Update Nilai & Feedback
  activate Task
  Task -> DB: Update
  activate DB
  DB --> Task: Updated
  deactivate DB
  Task --> LaporanController: Nilai Tersimpan
  deactivate Task
  
  LaporanController --> Guru: Konfirmasi Penilaian
end

deactivate LaporanController

== Grade Soal (Otomatis) ==
Guru -> SoalController: Trigger Re-Grade
activate SoalController

SoalController -> ExercisePoint: Ambil Exercise Point
activate ExercisePoint
ExercisePoint -> DB: Retrieve with Relations
activate DB
DB --> ExercisePoint: Data
deactivate DB
ExercisePoint --> SoalController: Data dengan Jawaban
deactivate ExercisePoint

SoalController -> SoalController: Hitung Skor

loop Untuk Setiap Item
  SoalController -> SoalController: Bandingkan Jawaban
  alt Jawaban Benar
    SoalController -> SoalController: Tambah Poin
  end
end

SoalController -> SoalController: Hitung Persentase

SoalController -> ExercisePoint: Update Skor
activate ExercisePoint
ExercisePoint -> DB: Update
activate DB
DB --> ExercisePoint: Updated
deactivate DB
ExercisePoint --> SoalController: Skor Tersimpan
deactivate ExercisePoint

SoalController --> Guru: Tampilkan Hasil

deactivate SoalController

@enduml
