@startuml DashboardGuru-UseCase

left to right direction
skinparam packageStyle rectangle

actor "Guru" as Guru

rectangle "Dashboard Guru System" {
  
  package "Manajemen Aplikasi" {
    usecase "Pilih Aplikasi" as UC1
    usecase "Dashboard Aplikasi" as UC2
  }
  
  package "Manajemen Kelas" {
    usecase "Kelola Kelas" as UC3
    usecase "Tambah Siswa Manual" as UC4
    usecase "Import Siswa CSV" as UC5
    usecase "Hapus Siswa" as UC6
  }
  
  package "Manajemen Materi" {
    usecase "Lihat Materi Admin" as UC7
    usecase "Bagikan Materi ke Kelas" as UC8
    usecase "Buat Materi Custom" as UC9
    usecase "Edit/Hapus Materi" as UC10
  }
  
  package "Manajemen Soal/Ujian" {
    usecase "Lihat Soal Admin" as UC11
    usecase "Bagikan Soal ke Kelas" as UC12
    usecase "Buat Soal Custom" as UC13
    usecase "Kelola Soal (UH/PTS/PAS)" as UC14
  }
  
  package "Manajemen Tugas" {
    usecase "Buat Tugas" as UC15
    usecase "Edit/Hapus Tugas" as UC16
    usecase "Lihat Pengumpulan" as UC17
    usecase "Beri Nilai Tugas" as UC18
  }
  
  package "Laporan & Nilai" {
    usecase "Lihat Laporan Harian" as UC19
    usecase "Rekap Nilai Kelas" as UC20
    usecase "Rekap Nilai Siswa" as UC21
    usecase "Download PDF Rekap" as UC22
  }
  
  package "Kelas Online" {
    usecase "Buat Meeting Online" as UC23
    usecase "Kelola Meeting" as UC24
  }
  
  package "Pengaturan" {
    usecase "Update Profile" as UC25
    usecase "Ubah Password" as UC26
  }
}

' Guru relationships
Guru --> UC1
Guru --> UC2
Guru --> UC3
Guru --> UC4
Guru --> UC5
Guru --> UC6
Guru --> UC7
Guru --> UC8
Guru --> UC9
Guru --> UC10
Guru --> UC11
Guru --> UC12
Guru --> UC13
Guru --> UC14
Guru --> UC15
Guru --> UC16
Guru --> UC17
Guru --> UC18
Guru --> UC19
Guru --> UC20
Guru --> UC21
Guru --> UC22
Guru --> UC23
Guru --> UC24
Guru --> UC25
Guru --> UC26

' Include relationships
UC5 ..> UC4 : <<include>>
UC22 ..> UC20 : <<include>>
UC22 ..> UC21 : <<include>>

' Extend relationships
UC8 ..> UC7 : <<extend>>
UC12 ..> UC11 : <<extend>>
UC18 ..> UC17 : <<extend>>

@enduml
