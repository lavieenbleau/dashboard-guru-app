@startuml ShareContent-Activity
!theme plain
scale 0.75
skinparam dpi 150

title Activity Diagram: Bagikan Konten ke Kelas

|Guru|
start
:Pilih konten (Materi/Tugas/Soal);
:Klik "Bagikan";

|Sistem|
:Tampilkan modal share;
:Load daftar kelas;
:Tampilkan checkbox "Pilih Semua Kelas";
:Tampilkan toggle "Bagikan sebagai Tugas";

|Guru|
if (Pilih semua?) then (ya)
  :Klik checkbox "Pilih Semua Kelas";
  |Sistem|
  :Check semua kelas otomatis;
else (tidak)
  :Pilih kelas tujuan manual;
endif

if (Bagikan sebagai tugas?) then (ya)
  :Toggle "Bagikan sebagai Tugas";
  |Sistem|
  :Tampilkan input deadline;
  |Guru|
  :Set deadline;
endif

:Submit;

|Sistem|
:Validasi input;

if (Valid?) then (ya)
  :Sync classrooms ke pivot table;
  
  if (as_task = true?) then (ya)
    repeat
      :Ambil classroom berikutnya;
      :Create Post record dengan:\n- is_task=1\n- deadline=input\n- shared_to_classes JSON;
    repeat while (Masih ada classrooms?) is (ya)
    ->tidak;
  endif
  
  if (Konten = Soal?) then (ya)
    :Create exercise_points untuk siswa;
  endif
  
  :Tampilkan success;
  |Guru|
  stop
else (tidak)
  :Tampilkan error;
  |Guru|
  stop
endif

@enduml
  
  |System|
  :Tampilkan materi admin\nper tema/subtema;
  
  |Guru|
  :Pilih materi yang akan dibagikan;
  
  note right
  Materi admin adalah konten
  built-in yang sudah ada
  di sistem
  end note

else (Tugas)
  :Akses menu Tugas;
  
  |System|
  :Tampilkan daftar mapel;
  
  |Guru|
  :Pilih mapel;
  
  |System|
  :Tampilkan tugas yang sudah dibuat;
  
  |Guru|
  :Pilih tugas yang akan dibagikan;

else (Soal)
  :Akses menu Soal;
  
  |System|
  :Tampilkan kategori soal;
  
  |Guru|
  :Pilih kategori & tema;
  
  |System|
  :Tampilkan daftar soal;
  
  |Guru|
  if (Mode share?) then (Single)
    :Pilih 1 soal;
  else (Bulk)
    :Pilih multiple soal\n(checkbox);
  endif
endif

:Klik tombol "Bagikan";

|System|
:Tampilkan modal/form share;
:Load daftar kelas tersedia;

|Guru|
:Pilih kelas tujuan\n(bisa multiple);

if (Set jadwal?) then (ya)
  :Input tanggal mulai\n(share_date);
  :Input deadline (optional);
  
  |System|
  :Validasi tanggal;
  
  if (Tanggal valid?) then (tidak)
    :Error: Tanggal tidak valid\n(deadline > share_date);
    |Guru|
    stop
  endif
endif

:Submit form share;

|System|
:Validasi input;

if (Minimal 1 kelas dipilih?) then (tidak)
  :Error: Pilih minimal 1 kelas;
  |Guru|
  stop
else (ya)
  fork
    :Initialize:\n- sharedCount = 0\n- skippedCount = 0\n- errors = [];
  end fork
  
  if (Share mode?) then (Single Content)
    
    repeat
      :Ambil kelas berikutnya;
      
      |System|
      :Check apakah konten sudah dibagikan\nke kelas ini;
      
      if (Sudah dibagikan?) then (ya)
        :skippedCount++;
        :Add to errors:\n"Kelas X: Sudah dibagikan";
      else (tidak)
        fork
          :Insert lesson_items:\n- lesson_id/post_id/exercise_id\n- classroom_id\n- share_date\n- deadline;
        fork again
          if (Konten = Soal?) then (ya)
            :Get semua siswa di kelas;
            
            repeat
              :Create exercise_points\nuntuk setiap siswa:\n- exercise_id\n- student_id\n- exercise_point: null\n- is_correct: null;
            repeat while (Ada siswa lagi?) is (ya)
            ->tidak;
          endif
        end fork
        
        :sharedCount++;
      endif
      
    repeat while (Ada kelas lagi?) is (ya)
    ->tidak;
    
  else (Bulk Share - Multiple Content)
    
    repeat
      :Ambil konten berikutnya;
      
      repeat
        :Ambil kelas berikutnya;
        
        |System|
        :Check duplikasi;
        
        if (Sudah dibagikan?) then (ya)
          :skippedCount++;
        else (tidak)
          fork
            :Insert lesson_items;
          fork again
            if (Konten = Soal?) then (ya)
              :Create exercise_points\nuntuk semua siswa;
            endif
          end fork
          
          :sharedCount++;
        endif
        
      repeat while (Ada kelas lagi?) is (ya)
      ->tidak;
      
    repeat while (Ada konten lagi?) is (ya)
    ->tidak;
  endif
  
  :Build success message:\n"{sharedCount} konten berhasil dibagikan";
  
  if (Ada skipped?) then (ya)
    :Append message:\n"{skippedCount} sudah dibagikan sebelumnya";
  endif
  
  if (Ada errors?) then (ya)
    :Attach error details;
  endif
  
  note right
  Optional:
  - Send notification ke siswa
  - Log sharing activity
  - Update dashboard statistics
  end note
  
  :Redirect dengan success message;
  
  |Guru|
  :Lihat hasil sharing;
  
  if (Ada errors?) then (ya)
    :Review error list;
    
    if (Retry failed?) then (ya)
      :Ulangi proses share\nuntuk yang gagal;
      |System|
    else (tidak)
      stop
    endif
  else (tidak)
    stop
  endif
endif

@enduml
