@startuml ManageClassroom-Activity

title Activity Diagram: Kelola Kelas

|Guru|
start
:Akses menu Kelas;

|Sistem|
:Tampilkan daftar kelas;

|Guru|
if (Aksi?) then (Buat Kelas)
  :Klik "Tambah Kelas";
  :Input nama kelas;
  :Input deskripsi;
  :Submit;
  
  |Sistem|
  :Validasi data;
  
  if (Valid?) then (ya)
    :Simpan kelas;
    :Tampilkan success;
    |Guru|
    stop
  else (tidak)
    :Tampilkan error;
    |Guru|
    stop
  endif

else (Hapus Kelas)
  :Pilih kelas;
  :Klik "Hapus";
  :Konfirmasi;
  
  |Sistem|
  :Delete kelas;
  :Tampilkan success;
  |Guru|
  stop

else (Lihat Dashboard)
  :Pilih kelas;
  
  |Sistem|
  :Load data kelas & siswa;
  :Tampilkan dashboard kelas;
  |Guru|
  stop
endif

@enduml
