@startuml RekapNilai-Activity

title Activity Diagram: Rekap Nilai & Export PDF

|Guru|
start
:Akses menu Rekap Nilai;

|Sistem|
:Tampilkan daftar kelas;

|Guru|
:Pilih kelas;

|Sistem|
:Load data siswa & nilai;
:Hitung rata-rata tugas;
:Hitung rata-rata soal;
:Tampilkan tabel rekap;

|Guru|
if (Aksi?) then (Lihat Detail Siswa)
  :Klik nama siswa;
  
  |Sistem|
  :Load detail nilai siswa;
  :Tampilkan grafik progress;
  |Guru|
  stop

else (Download PDF Kelas)
  :Klik "Download PDF Kelas";
  
  |Sistem|
  :Generate PDF rekap kelas;
  :Download file;
  |Guru|
  stop

else (Download PDF Siswa)
  :Pilih siswa;
  :Klik "Download PDF";
  
  |Sistem|
  :Generate PDF detail siswa;
  :Download file;
  |Guru|
  stop
endif

@enduml

|Guru|
if (Punya banyak aplikasi?) then (ya)
  |System|
  :Tampilkan list aplikasi;
  
  fork
    :Loop setiap aplikasi;
    
    fork
      :Count total kelas;
    fork again
      :Count total siswa;
    fork again
      :Count total konten;
    end fork
  end fork
  
  :Tampilkan grid aplikasi\ndengan statistik;
  
  |Guru|
  :Pilih aplikasi;
  
else (tidak - langsung 1 aplikasi)
  |System|
  :Auto-redirect ke dashboard aplikasi;
endif

|System|
:Load dashboard aplikasi;

fork
  :Count total kelas;
fork again
  :Count total siswa;
fork again
  :Count total konten (materi, tugas, soal);
fork again
  :Count pending grades\n(tugas belum dinilai);
fork again
  :Get recent posts\n(limit 5);
fork again
  :Get recent submissions\n(limit 10);
fork again
  :Get today's meetings;
end fork

:Render dashboard dengan:\n- Statistics cards\n- Recent activity\n- Quick actions\n- Upcoming meetings;

|Guru|
:Lihat overview dashboard;

if (Aksi quick?) then (Lihat Pending Grades)
  :Klik "X Tugas Belum Dinilai";
  
  |System|
  :Redirect ke Laporan Harian;
  :Filter: pending only;
  
  |Guru|
  :Lihat list tugas pending;
  stop

else (Lihat Recent Activity)
  :Scroll recent submissions;
  
  |System|
  :Tampilkan list:\n- Nama siswa\n- Tugas/Soal\n- Waktu pengumpulan\n- Status (dinilai/pending);
  
  |Guru|
  if (Klik submission?) then (ya)
    |System|
    :Redirect ke detail submission;
    
    |Guru|
    stop
  else (tidak)
    stop
  endif

else (Quick Create)
  if (Create?) then (Tugas Baru)
    :Klik "Buat Tugas";
    
    |System|
    :Redirect ke form create tugas;
    
    |Guru|
    stop
    
  else (Soal Baru)
    :Klik "Buat Soal";
    
    |System|
    :Redirect ke form create soal;
    
    |Guru|
    stop
    
  else (Meeting Baru)
    :Klik "Mulai Meeting";
    
    |System|
    :Redirect ke quick start meeting;
    
    |Guru|
    stop
  endif

else (View Statistics Detail)
  :Klik statistics card;
  
  if (Card?) then (Total Kelas)
    |System|
    :Redirect ke daftar kelas;
    
    |Guru|
    stop
    
  else (Total Siswa)
    |System|
    :Redirect ke rekap siswa;
    
    |Guru|
    stop
    
  else (Total Konten)
    |System|
    :Tampilkan breakdown:\n- X Materi\n- Y Tugas\n- Z Soal;
    
    |Guru|
    stop
  endif

else (Calendar View)
  :Klik "Lihat Kalender";
  
  |System|
  fork
    :Load meetings scheduled;
  fork again
    :Load tugas deadlines;
  fork again
    :Load soal deadlines;
  end fork
  
  :Render calendar dengan:\n- Meetings (blue)\n- Deadlines tugas (red)\n- Deadlines soal (green);
  
  |Guru|
  :Lihat jadwal lengkap;
  
  if (Klik tanggal?) then (ya)
    |System|
    :Tampilkan detail events\npada tanggal tersebut;
    
    |Guru|
    if (Klik event?) then (ya)
      |System|
      :Redirect ke detail event;
      
      |Guru|
      stop
    else (tidak)
      stop
    endif
  else (tidak)
    stop
  endif

else (Search)
  :Gunakan search bar;
  :Input keyword;
  
  |System|
  fork
    :Search di materi (title, description);
  fork again
    :Search di tugas (title, description);
  fork again
    :Search di soal (title);
  fork again
    :Search di siswa (name, nis, email);
  end fork
  
  :Tampilkan hasil search:\n- Grouped by type\n- Highlight keyword;
  
  |Guru|
  if (Klik hasil?) then (ya)
    |System|
    :Redirect ke detail item;
    
    |Guru|
    stop
  else (tidak)
    stop
  endif

else (Notifications)
  :Klik icon notifikasi;
  
  |System|
  :Load notifications:\n- Pengumpulan baru\n- Meeting akan dimulai\n- Deadline approaching;
  
  :Tampilkan dropdown notifications;
  
  |Guru|
  if (Klik notifikasi?) then (ya)
    |System|
    :Mark as read;
    :Redirect ke related page;
    
    |Guru|
    stop
  else (tidak)
    stop
  endif

else (Profile & Settings)
  :Klik profile menu;
  
  |System|
  :Tampilkan dropdown:\n- Profile\n- Pengaturan\n- Logout;
  
  |Guru|
  if (Menu?) then (Profile)
    |System|
    :Redirect ke profile page;
    |Guru|
    stop
    
  else (Pengaturan)
    |System|
    :Redirect ke settings page;
    |Guru|
    stop
    
  else (Logout)
    |System|
    :Destroy session;
    :Redirect ke login;
    |Guru|
    stop
  endif
endif

@enduml
