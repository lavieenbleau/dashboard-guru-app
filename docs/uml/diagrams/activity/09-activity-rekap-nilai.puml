@startuml ActivityDiagram-RekapNilai
!theme plain
scale 0.75
skinparam dpi 150

title Activity Diagram: Rekap Nilai & Export PDF

|Guru|
start
:Navigasi ke menu "Rekap Nilai";

|Sistem|
:Query semua kelas\nberdasarkan serial_id;
:Tampilkan daftar kelas;

|Guru|
:Pilih kelas;

|Sistem|
:Query data siswa di kelas;
:Query semua mata pelajaran;

repeat
  :Ambil mapel berikutnya;
  :Query semua Posts (tugas)\nuntuk mapel ini;
  :Query semua Exercises (UH/PTS/PAS)\nuntuk mapel ini;
  :Numbering tasks (1,2,3...)\ndan exercises per type;
  
  repeat
    :Ambil siswa berikutnya;
    
    repeat
      :Ambil task berikutnya;
      :Get individual task.point\nfor this student;
      :Simpan ke array scores;
    repeat while (Masih ada tasks?) is (ya)
    ->tidak;
    
    repeat
      :Ambil exercise berikutnya;
      :Get individual exercise_point.exercise_point\nfor this student;
      :Simpan ke array scores per type\n(UH/PTS/PAS);
    repeat while (Masih ada exercises?) is (ya)
    ->tidak;
    
    :Hitung rata-rata nilai\nper student per mapel;
    
  repeat while (Masih ada siswa?) is (ya)
  ->tidak;
  
repeat while (Masih ada mapel?) is (ya)
->tidak;

:Render tabel per-mapel\ndengan individual scores;
:Display: Tugas 1,2,3 | UH 1,2 | PTS | PAS | Rata-rata;
:Tampilkan ke browser;

|Guru|
if (Pilih aksi?) then (Download PDF Kelas)
  :Klik "Download PDF"\ndi header;
  
  |Sistem|
  :Load view PDF\n'rekap-nilai.pdf.class';
  :Set paper landscape A4;
  :Query ulang data dengan logic sama\n(individual scores per task/exercise);
  :Render HTML per-mapel tables\ndengan font 8px;
  :Konversi HTML ke PDF\nmenggunakan DomPDF;
  :Set filename:\nRekap-Nilai-{NamaKelas}.pdf;
  :Send file download;
  
  |Guru|
  :Simpan file PDF;
  
elseif (Lihat Detail Siswa) then
  :Klik tombol "Detail"\npada siswa;
  
  |Sistem|
  :Query student detail;
  :Query semua tugas siswa\nwith post.mapel;
  :Query semua exercise_points\nwith exercise.lesson.mapel;
  :Hitung rata-rata tugas;
  :Hitung rata-rata soal;
  :Tampilkan halaman detail;
  
  |Guru|
  if (Download PDF Siswa?) then (ya)
    :Klik "Download PDF";
    
    |Sistem|
    :Load view PDF\n'rekap-nilai.pdf.student';
    :Set paper portrait A4;
    :Render header:\n- Nama siswa\n- Kelas\n- Tanggal cetak;
    :Render tabel nilai tugas;
    :Render tabel nilai soal;
    :Render rata-rata per tabel;
    :Konversi HTML ke PDF;
    :Set filename:\nRekap-Nilai-{NamaSiswa}.pdf;
    :Send file download;
    
    |Guru|
    :Simpan file PDF;
  else (tidak)
    :Lihat detail di browser;
  endif
  
elseif (Kembali) then
  :Klik tombol "Kembali";
  
  |Sistem|
  :Redirect ke daftar kelas;
endif

|Guru|
stop

@enduml
