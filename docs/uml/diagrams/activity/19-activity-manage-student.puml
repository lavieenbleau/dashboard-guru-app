@startuml ManageStudent-Activity

title Activity Diagram: Kelola Data Siswa

|Guru|
start
:Pilih aplikasi & kelas;

|Sistem|
:Tampilkan dashboard kelas;

|Guru|
if (Aksi?) then (Tambah Manual)
  :Klik "Tambah Siswa";
  :Input data siswa;
  :Submit;
  
  |Sistem|
  :Validasi data;
  
  if (Valid?) then (ya)
    :Simpan siswa;
    :Tampilkan success;
    |Guru|
    stop
  else (tidak)
    :Tampilkan error;
    |Guru|
    stop
  endif

else (Import CSV)
  :Klik "Import CSV";
  :Upload file CSV;
  
  |Sistem|
  :Validasi file;
  
  if (File valid?) then (ya)
    :Parse CSV;
    :Proses setiap baris;
    :Simpan ke database;
    :Tampilkan hasil import;
    |Guru|
    stop
  else (tidak)
    :Tampilkan error;
    |Guru|
    stop
  endif

else (Edit)
  :Pilih siswa;
  :Klik "Edit";
  :Update data;
  :Submit;
  
  |Sistem|
  :Validasi data;
  
  if (Valid?) then (ya)
    :Update siswa;
    :Tampilkan success;
    |Guru|
    stop
  else (tidak)
    :Tampilkan error;
    |Guru|
    stop
  endif

else (Hapus)
  :Pilih siswa;
  :Klik "Hapus";
  :Konfirmasi;
  
  |Sistem|
  :Delete siswa;
  :Tampilkan success;
  |Guru|
  stop
endif

@enduml
